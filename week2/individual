--edasijõudnute ülesanded:
--null nimede asendamine:
UPDATE customers_test
SET first_name = 'Tundmatu'
WHERE first_name IS NULL OR first_name = '';
--linnanimed muudan kõik ühesuguseks ehk suur algustäht:
UPDATE customers_test
SET city = INITCAP(TRIM(city))
WHERE city != INITCAP(TRIM(city));
--e-mailide korrastus, et e-mailid oleksid ka kõik samasuguste tähtedega- väikesed.
UPDATE customers_test
SET email = LOWER(TRIM(email))
WHERE email != LOWER(TRIM(email));
--linnade kontroll:
SELECT city, COUNT(*) AS arv
FROM customers_test
GROUP BY city
ORDER BY city;
--telefoni nr korda:
SELECT phone,
    CASE
        WHEN phone LIKE '+372%' THEN phone
        WHEN phone LIKE '372%' THEN '+' || phone
        WHEN LENGTH(phone) = 7 THEN '+372' || phone
        ELSE phone
    END AS standardne_telefon
FROM customers_test
WHERE phone IS NOT NULL
LIMIT 50;
--vaatan kas on valesid formaate>
SELECT phone
FROM customers_test
WHERE phone NOT LIKE '+%';

SELECT phone
FROM customers_test
WHERE phone LIKE '372%';

SELECT phone
FROM customers_test
WHERE LENGTH(phone) = 7;
-- kõik telefoni numbrid olid juba antud tabelid õiges formaadis, muutma ei pea. vähemalt see kriteeriumid mis ette olid antud.
